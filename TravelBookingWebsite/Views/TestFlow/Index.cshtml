@model List<TravelBookingWebsite.Models.HotelDto>
@* Nhớ sửa lại tên namespace TravelBookingWebsite cho đúng với Project của mày nhé *@

@{
    ViewData["Title"] = "Test Luồng Khai Phá Dữ Liệu";
}

<div class="container mt-5" style="font-family: Arial, sans-serif;">
    <h2 class="text-center mb-4 text-primary fw-bold">TEST LUỒNG ĐỀ XUẤT COMBO DU LỊCH</h2>

    @if (ViewBag.DbError != null)
    {
        <div class="alert alert-danger shadow-sm">
            <strong>❌ LỖI KẾT NỐI DATABASE:</strong> @ViewBag.DbError
            <br /> <small>Mày check lại chuỗi kết nối (Server, Tên DB) trong Controller nhé!</small>
        </div>
    }

    <div class="card mb-4 shadow-sm border-0 bg-light">
        <div class="card-body">
            <h4 class="text-dark">1. Hành động của khách hàng</h4>
            <p class="mb-0 fs-5">Khách đang xem/bỏ vào giỏ hàng dịch vụ: <strong class="text-primary">[@ViewBag.CartItem]</strong></p>
        </div>
    </div>

    <div class="card mb-4 shadow-sm border-0" style="background-color: #e8f5e9;">
        <div class="card-body">
            <h4 class="text-success">2. Trích xuất Tri thức (Từ SQL Server - Bảng Luat_FPGrowth)</h4>

            @if (!string.IsNullOrEmpty(ViewBag.AiRule))
            {
                <div class="mt-3 p-3 bg-white rounded border-start border-5 border-success">
                    <p class="fs-5 mb-2">✅ <strong>Luật khai phá khớp lệnh:</strong></p>
                    <p class="fs-5">
                        Nếu khách mua <strong>[@ViewBag.CartItem]</strong> $\rightarrow$ Hệ thống gợi ý mã: <strong class="text-danger">[@ViewBag.AiRule]</strong>
                    </p>
                    <p class="mb-0 fs-5">📊 <strong>Độ tin cậy (Confidence):</strong> <span class="text-success fw-bold">@ViewBag.Confidence %</span></p>
                </div>
            }
            else
            {
                <p class="text-danger mt-3 fw-bold">❌ Không tìm thấy luật nào trong Database cho dịch vụ này.</p>
            }
        </div>
    </div>

    <div class="card mb-4 shadow-sm border-0 bg-light">
        <div class="card-body">
            <h4 class="text-warning text-darken">3. Hiển thị thực tế (Chọc Nuitee LiteAPI)</h4>

            @if (Model != null && Model.Count > 0)
            {
                <p class="text-muted">Nhận được lệnh <strong>[@ViewBag.AiRule]</strong>, C# đã gọi LiteAPI kéo dữ liệu phòng thật về:</p>

                <div class="row mt-3">
                    @foreach (var item in Model)
                    {
                        <div class="col-md-4">
                            <div class="card h-100">
                                @if (!string.IsNullOrEmpty(item.MainPhoto))
                                {
                                    <img src="@item.MainPhoto" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <img src="https://via.placeholder.com/300x200?text=No+Image" class="card-img-top" alt="No image" style="height: 200px; object-fit: cover;">
                                }
                                <div class="card-body">
                                    <h6 class="card-title fw-bold">@item.Name</h6>
                                    <p class="card-text small text-muted">Mã API: @item.Id</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">Đang chờ lệnh hoặc không có dữ liệu trả về từ API.</p>
            }
        </div>
    </div>
</div>