@{
    ViewData["Title"] = "Tìm Kiếm Tour Tham Quan";
}

<div class="container mt-5">
    <h2 class="fw-bold mb-4 text-primary"><i class="bi bi-map"></i> Khám Phá Tour Tham Quan</h2>

    <div class="row mb-5">
        <div class="col-md-8 mx-auto">
            <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                <input type="text" id="tourQuery" class="form-control border-0 px-4" placeholder="Nhập điểm đến (VD: Vietnam, Da Nang, Ha Long)..." style="box-shadow: none;">
                <button class="btn btn-primary px-4 fw-bold" onclick="timTour()">
                    <i class="bi bi-search"></i> Tìm Tour Ngay
                </button>
            </div>
        </div>
    </div>

    <div class="row" id="ketQuaTour">
    </div>
</div>

<script>
    function timTour() {
        // Lấy từ khóa người dùng gõ
        let query = document.getElementById('tourQuery').value.trim();
        if(!query) {
            alert("Đại ca ơi, nhập chữ vào đã chứ!");
            return;
        }

        // Hiện hiệu ứng Loading xoay xoay cho nó Pro
        let container = document.getElementById('ketQuaTour');
        container.innerHTML = `
            <div class="col-12 text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <h5 class="mt-3 text-muted">Hệ thống đang rà soát Tour từ RapidAPI...</h5>
            </div>`;

        // Bắn AJAX lên cái C# Controller lúc nãy
            // ... (Giữ nguyên đoạn trên cho tới fetch)
    fetch(`/Tour/SearchTour?query=${encodeURIComponent(query)}`)
        .then(response => response.json())
        .then(data => {
            console.log("DỮ LIỆU GỐC TỪ TOURRADAR TRẢ VỀ ĐÂY ĐẠI CA:", data);

            // SỬA TẠI ĐÂY: Hãy bật F12 Inspect lên xem màn hình Console để biết chính xác mảng Tour nằm ở đâu.
            // Tạm thời lấy theo code cũ của bạn hoặc bổ sung thêm trường hợp dự phòng:
            let listTours = data.data?.tours || data.tours || data.items || [];

            if (listTours && listTours.length > 0) {
                let html = '';

                listTours.forEach(tour => {
                    let title = tour.name || "Không có tên";
                    let image = tour.photoThumbnailUrl ? "https://" + tour.photoThumbnailUrl : "https://via.placeholder.com/400x250";
                    let price = tour.price ? `${tour.price.minValue} ${tour.price.currencyCode}` : "Liên hệ";
                    let duration = tour.durationDays ? `${tour.durationDays} ngày` : "Đang cập nhật";

                    // SỬA TẠI ĐÂY: Khai báo thêm biến link để không bị lỗi "undefined"
                    let link = tour.url || tour.link || "#";

                    html += `
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                            <img src="${image}" class="card-img-top" alt="Ảnh Tour" style="height: 220px; object-fit: cover;">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title fw-bold text-dark mb-3">${title}</h5>
                                <div class="mt-auto">
                                    <p class="text-muted small mb-1">
                                        <i class="bi bi-clock"></i> Thời gian: <span class="fw-bold">${duration}</span>
                                    </p>
                                    <h4 class="text-danger fw-bold mt-2">Từ ${price}</h4>
                                </div>
                            </div>
                            <div class="card-footer bg-white border-0 pb-3 pt-0">
                                <a href="${link}" target="_blank" class="btn btn-outline-primary w-100 fw-bold">Xem Lịch Trình</a>
                            </div>
                        </div>
                    </div>`;
                });

                container.innerHTML = html;
            } else {
                container.innerHTML = `<div class="col-12 text-center text-danger mt-4"><h5>Không tìm thấy Tour nào khớp với "${query}". Thử lại nhé!</h5></div>`;
            }
        })
        .catch(error => {
            console.error("Lỗi chọc API:", error);
            container.innerHTML = `<div class="col-12 text-center text-danger mt-4"><h5>Lỗi kết nối Server!</h5></div>`;
        });
    }

    // Tiện tay: Ấn Enter ở ô Input thì cũng chạy hàm Tìm kiếm
    document.getElementById("tourQuery").addEventListener("keypress", function(event) {
        if (event.key === "Enter") {
            event.preventDefault();
            document.querySelector(".btn-primary").click();
        }
    });
</script>