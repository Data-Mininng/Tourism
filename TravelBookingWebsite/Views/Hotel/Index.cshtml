@model List<TravelBookingWebsite.Models.HotelDto> 

@{
    ViewData["Title"] = "Gợi Ý Khách Sạn Việt Nam";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-uppercase text-primary">Kết Quả Gọi Live API Từ Nuitee LiteAPI</h2>
        <p class="text-muted">Ảnh thật, thông tin thật chạy thời gian thực qua Backend C#</p>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm" style="border-radius: 12px; overflow: hidden; border: 1px solid #eef2f3;">
                        
                        @if (!string.IsNullOrEmpty(item.MainPhoto))
                        {
                            <img src="@item.MainPhoto" class="card-img-top" alt="@item.Name" style="height: 220px; object-fit: cover;">
                        }
                        else
                        {
                            <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600" class="card-img-top" alt="No Image" style="height: 220px; object-fit: cover;">
                        }
                        
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="badge bg-warning text-dark">⭐ @item.Stars Sao</span>
                                    <small class="text-muted">Mã: @item.Id</small>
                                </div>
                                <h5 class="card-title text-dark fw-bold" style="font-size: 1.1rem; line-height: 1.4;">@item.Name</h5>
                                <p class="card-text text-muted small mb-0"><i class="bi bi-geo-alt-fill text-danger"></i> @item.Address, @item.City</p>
                            </div>
                            
                            <div class="mt-3">
                                <hr style="border-top: 1px dashed #dfdfdf;">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">Giá tham khảo</small>
                                        <span class="text-danger fw-bold" style="font-size: 1.2rem;">1.850.000 đ</span>
                                    </div>
                                    <a href="#" class="btn btn-primary btn-sm px-3" style="border-radius: 8px;">Chọn Phòng</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <div class="alert alert-warning">Không lấy được dữ liệu từ API. Hãy kiểm tra lại X-API-Key hoặc kết nối mạng!</div>
            </div>
        }
    </div>
</div>