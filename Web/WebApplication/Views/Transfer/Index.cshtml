@model IEnumerable<TravelApp.Models.Transfer>

@{
    ViewData["Title"] = "Phương Tiện Di Chuyển";
}

<div class="page-header">
    <div>
        <h1 class="text-3xl fw-bold">Phương Tiện Di Chuyển</h1>
        <p class="muted mt-2">Quản lý tất cả các phương tiện vận chuyển hành khách</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        Thêm phương tiện
    </a>
</div>

<div class="section">
    @if (!Model.Any())
    {
        <div class="card" style="text-align:center; padding:3rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 1rem;">
                <rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle>
            </svg>
            <p class="muted">Chưa có phương tiện nào được thêm.</p>
            <a asp-action="Create" class="btn btn-primary mt-4">Thêm phương tiện đầu tiên</a>
        </div>
    }
    else
    {
        <div class="search-grid sg-3">
            @foreach (var item in Model)
            {
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-center" style="justify-content:space-between; margin-bottom:1rem;">
                            <span class="badge @(item.Type == "Máy bay" ? "badge-blue" : item.Type == "Xe khách" ? "badge-green" : item.Type == "Tàu hỏa" ? "badge-amber" : "badge-blue")">
                                @item.Type
                            </span>
                            <span class="muted2 text-xs">#@item.Id</span>
                        </div>

                        <div class="d-flex align-center gap-2 mb-3">
                            <div style="flex:1;">
                                <p class="text-xs muted">Điểm đi</p>
                                <p class="fw-semi">@item.FromLocation</p>
                            </div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                            <div style="flex:1;">
                                <p class="text-xs muted">Điểm đến</p>
                                <p class="fw-semi">@item.ToLocation</p>
                            </div>
                        </div>

                        <div class="d-flex align-center gap-3 mb-3" style="flex-wrap:wrap;">
                            <div class="d-flex align-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                <span class="text-sm muted">@item.DepartureTime.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="d-flex align-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
                                <span class="text-sm muted">@item.Capacity chỗ</span>
                            </div>
                        </div>

                        <div class="d-flex align-center" style="justify-content:space-between; border-top:1px solid var(--border); padding-top:0.75rem;">
                            <div>
                                <span class="price-big" style="font-size:1.1rem;">@item.Price.ToString("N0") ₫</span>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline" style="padding:0.4rem 0.75rem; font-size:0.8rem;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline" style="padding:0.4rem 0.75rem; font-size:0.8rem;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline" style="padding:0.4rem 0.75rem; font-size:0.8rem; color:#ef4444; border-color:#ef4444;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
