@model TravelApp.Models.Transfer

@{
    ViewData["Title"] = "Chỉnh Sửa Phương Tiện";
}

<div class="page-header">
    <div>
        <h1 class="text-3xl fw-bold">Chỉnh Sửa Phương Tiện</h1>
        <p class="muted mt-2">Cập nhật thông tin phương tiện #@Model.Id</p>
    </div>
    <a asp-action="Index" class="btn btn-outline">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Quay lại
    </a>
</div>

<div class="section">
    <div class="card" style="max-width:720px;">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="muted" style="color:#ef4444; margin-bottom:1rem;"></div>
                <input type="hidden" asp-for="Id" />

                <div class="form-group">
                    <label asp-for="Type" class="fw-semi">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; vertical-align:middle; margin-right:0.25rem;"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
                        Loại phương tiện
                    </label>
                    <select asp-for="Type" class="form-control">
                        <option value="">-- Chọn loại phương tiện --</option>
                        <option value="Máy bay">Máy bay</option>
                        <option value="Xe khách">Xe khách</option>
                        <option value="Tàu hỏa">Tàu hỏa</option>
                        <option value="Xe limousine">Xe limousine</option>
                        <option value="Phà">Phà</option>
                    </select>
                    <span asp-validation-for="Type" style="color:#ef4444; font-size:0.85rem;"></span>
                </div>

                <div class="search-grid sg-2">
                    <div class="form-group">
                        <label asp-for="FromLocation" class="fw-semi">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; vertical-align:middle; margin-right:0.25rem;"><circle cx="12" cy="10" r="3"></circle><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 6.9 8 11.7z"></path></svg>
                            Điểm đi
                        </label>
                        <input asp-for="FromLocation" class="form-control" placeholder="VD: Hà Nội" />
                        <span asp-validation-for="FromLocation" style="color:#ef4444; font-size:0.85rem;"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ToLocation" class="fw-semi">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; vertical-align:middle; margin-right:0.25rem;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                            Điểm đến
                        </label>
                        <input asp-for="ToLocation" class="form-control" placeholder="VD: TP. Hồ Chí Minh" />
                        <span asp-validation-for="ToLocation" style="color:#ef4444; font-size:0.85rem;"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="DepartureTime" class="fw-semi">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; vertical-align:middle; margin-right:0.25rem;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        Thời gian khởi hành
                    </label>
                    <input asp-for="DepartureTime" type="datetime-local" class="form-control" />
                    <span asp-validation-for="DepartureTime" style="color:#ef4444; font-size:0.85rem;"></span>
                </div>

                <div class="search-grid sg-2">
                    <div class="form-group">
                        <label asp-for="Price" class="fw-semi">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; vertical-align:middle; margin-right:0.25rem;"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                            Giá vé (VNĐ)
                        </label>
                        <input asp-for="Price" type="number" class="form-control" placeholder="VD: 1500000" min="0" step="1000" />
                        <span asp-validation-for="Price" style="color:#ef4444; font-size:0.85rem;"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Capacity" class="fw-semi">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; vertical-align:middle; margin-right:0.25rem;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                            Sức chứa (người)
                        </label>
                        <input asp-for="Capacity" type="number" class="form-control" placeholder="VD: 50" min="1" />
                        <span asp-validation-for="Capacity" style="color:#ef4444; font-size:0.85rem;"></span>
                    </div>
                </div>

                <div class="d-flex gap-3 mt-4" style="justify-content:flex-end;">
                    <a asp-action="Index" class="btn btn-outline">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
