@model TravelApp.Models.User
@{
    ViewData["Title"] = "Trang cá nhân";
    
    // Thống kê số lượng theo loại dịch vụ từ Bookings
    int flightCount = Model.Bookings?.Count(b => b.BookingType == "Flight") ?? 0;
    int hotelCount = Model.Bookings?.Count(b => b.BookingType == "Hotel") ?? 0;
    int tourCount = Model.Bookings?.Count(b => b.BookingType == "Tour") ?? 0;
    int carCount = Model.Bookings?.Count(b => b.BookingType == "Car") ?? 0;
    int transferCount = Model.Bookings?.Count(b => b.BookingType == "Transfer") ?? 0;
}

<div class="page-header" style="padding: 2rem 0;">
    <div class="container d-flex align-center gap-3">
        <img src="@(!string.IsNullOrEmpty(Model.AvatarUrl) ? Model.AvatarUrl : "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?q=80&w=200")" style="width:80px; height:80px; border-radius:50%; border:3px solid var(--accent); object-fit:cover;" alt="Avatar">
        <div>
            <h1 style="font-size:1.5rem; margin-bottom:0.2rem;">@Model.FullName</h1>
            <p class="badge badge-green">@Model.MemberLevel</p>
        </div>
    </div>
</div>

<div class="container py-4">
    <div class="results-layout" style="grid-template-columns: 240px 1fr; padding: 0;">
        <!-- Menu Sidebar -->
        <div class="filter-panel" style="padding: 1rem;">
            <div class="nav-mobile open" style="border:none; padding:0;">
                <a href="#" class="active" style="background:var(--accent); color:#000;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline; margin-right:8px; margin-bottom:-2px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> Hồ sơ cá nhân</a>
                <a href="#booking-history"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline; margin-right:8px; margin-bottom:-2px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg> Chuyến đi của tôi</a>
            </div>
        </div>

        <!-- Content -->
        <div>
            <!-- Tổng Quan -->
            <h3 class="fw-bold mb-4">Lịch sử dịch vụ đã sử dụng</h3>
            <div class="stats-grid mb-4">
                <div class="stat-card">
                    <div class="stat-value">@(flightCount)</div>
                    <div class="stat-label">Chuyến bay</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">@(hotelCount)</div>
                    <div class="stat-label">Khách sạn</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">@(tourCount)</div>
                    <div class="stat-label">Tour</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">@(carCount + transferCount)</div>
                    <div class="stat-label">Di chuyển</div>
                </div>
            </div>

            <!-- Thông Tin Cá Nhân -->
            <h4 class="mb-3">Thông Tin Chi Tiết</h4>
            <div class="card mb-5">
                <div class="card-body">
                    <div class="d-flex align-center mb-3">
                        <div class="muted" style="width:120px;">Họ và tên</div>
                        <div class="fw-semi">@Model.FullName</div>
                    </div>
                    <div class="d-flex align-center mb-3">
                        <div class="muted" style="width:120px;">Email</div>
                        <div class="fw-semi">@Model.Email</div>
                    </div>
                    <div class="d-flex align-center mb-3">
                        <div class="muted" style="width:120px;">Số điện thoại</div>
                        <div class="fw-semi">@(string.IsNullOrEmpty(Model.Phone) ? "Chưa cập nhật" : Model.Phone)</div>
                    </div>
                    <div class="d-flex align-center mb-3">
                        <div class="muted" style="width:120px;">Ngày sinh</div>
                        <div class="fw-semi">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</div>
                    </div>
                    <div class="d-flex align-center mb-3">
                        <div class="muted" style="width:120px;">Quê quán</div>
                        <div class="fw-semi">@(string.IsNullOrEmpty(Model.Hometown) ? "Chưa cập nhật" : Model.Hometown)</div>
                    </div>
                    <div class="d-flex align-center">
                        <div class="muted" style="width:120px;">Nơi ở hiện tại</div>
                        <div class="fw-semi">@(string.IsNullOrEmpty(Model.CurrentCity) ? "Chưa cập nhật" : Model.CurrentCity)</div>
                    </div>
                </div>
            </div>

            <!-- Lịch sử đặt dịch vụ -->
            <h4 class="mb-3" id="booking-history">Lịch Sử Đơn Đặt (Bill)</h4>
            @if (Model.Bookings == null || !Model.Bookings.Any())
            {
                <div class="card">
                    <div class="card-body text-center" style="padding: 2rem;">
                        <p class="muted mb-0">Bạn chưa đặt dịch vụ nào.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body" style="padding:0;">
                        <table style="width:100%; border-collapse: collapse;">
                            <thead>
                                <tr style="border-bottom: 1px solid var(--border); background: var(--surface);">
                                    <th style="padding: 1rem; text-align: left;" class="text-sm muted">Mã Đơn</th>
                                    <th style="padding: 1rem; text-align: left;" class="text-sm muted">Dịch Vụ</th>
                                    <th style="padding: 1rem; text-align: left;" class="text-sm muted">Ngày Đặt</th>
                                    <th style="padding: 1rem; text-align: left;" class="text-sm muted">Tổng Tiền</th>
                                    <th style="padding: 1rem; text-align: left;" class="text-sm muted">Trạng Thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in Model.Bookings.OrderByDescending(x => x.BookingDate))
                                {
                                    <tr style="border-bottom: 1px solid var(--border);">
                                        <td style="padding: 1rem;" class="fw-semi">#@b.Id</td>
                                        <td style="padding: 1rem;">
                                            <span class="badge @(b.BookingType == "Flight" ? "badge-blue" : b.BookingType == "Hotel" ? "badge-amber" : b.BookingType == "Tour" ? "badge-green" : "badge-blue")">
                                                @b.BookingType
                                            </span>
                                            <div class="text-xs muted2 mt-1">Ref ID: @b.ReferenceId</div>
                                        </td>
                                        <td style="padding: 1rem;" class="text-sm">@b.BookingDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td style="padding: 1rem;" class="fw-semi" style="color:var(--accent);">@b.TotalAmount.ToString("N0") ₫</td>
                                        <td style="padding: 1rem;">
                                            @if (b.Status == "Pending")
                                            {
                                                <span class="badge badge-amber" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">Chờ duyệt</span>
                                            }
                                            else if (b.Status == "Confirmed")
                                            {
                                                <span class="badge badge-green">Đã duyệt</span>
                                            }
                                            else if (b.Status == "Rejected")
                                            {
                                                <span class="badge" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">Đã hủy</span>
                                            }
                                            else
                                            {
                                                <span class="badge">@b.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>