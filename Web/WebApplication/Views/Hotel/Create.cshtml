@model Hotel
@{
    ViewData["Title"] = "Thêm khách sạn mới";
}

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Thêm <span class="accent">Khách sạn</span> mới
        </h1>
        <div class="meta-row">
            <div class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Điền thông tin khách sạn bên dưới
            </div>
        </div>
    </div>
</div>

<div class="section">
    <div class="container" style="max-width:720px;">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" style="color:#fca5a5; font-size:.85rem; margin-bottom:1rem;"></div>

                    <div class="search-grid sg-2 mb-4">
                        <div class="form-group">
                            <label asp-for="Name">Tên khách sạn <span class="accent">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="VD: Vinpearl Resort" />
                            <span asp-validation-for="Name" style="color:#fca5a5; font-size:.75rem;"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Location">Vị trí <span class="accent">*</span></label>
                            <input asp-for="Location" class="form-control" placeholder="VD: Nha Trang" />
                            <span asp-validation-for="Location" style="color:#fca5a5; font-size:.75rem;"></span>
                        </div>
                    </div>

                    <div class="search-grid sg-3 mb-4">
                        <div class="form-group">
                            <label asp-for="Stars">Số sao</label>
                            <select asp-for="Stars" class="form-control">
                                <option value="1">1 sao</option>
                                <option value="2">2 sao</option>
                                <option value="3">3 sao</option>
                                <option value="4">4 sao</option>
                                <option value="5">5 sao</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label asp-for="PricePerNight">Giá mỗi đêm (VNĐ)</label>
                            <input asp-for="PricePerNight" class="form-control" type="number" min="0" placeholder="VD: 1500000" />
                            <span asp-validation-for="PricePerNight" style="color:#fca5a5; font-size:.75rem;"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="HasPool">Có hồ bơi</label>
                            <select asp-for="HasPool" class="form-control">
                                <option value="false">Không</option>
                                <option value="true">Có</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-3" style="justify-content:flex-end; padding-top:1rem; border-top:1px solid var(--border);">
                        <a asp-action="Index" class="btn btn-outline">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                            Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            Lưu khách sạn
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
