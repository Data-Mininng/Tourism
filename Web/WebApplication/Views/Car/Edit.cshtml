@model TravelApp.Models.Car

@{
    ViewData["Title"] = "Chỉnh sửa xe";
}

<div class="page-header">
    <div class="container">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Chỉnh sửa xe
        </h1>
        <div class="meta-row">
            <div class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
                @Model.Brand @Model.Model — Mã #@Model.Id
            </div>
        </div>
    </div>
</div>

<div class="container" style="padding-top: 2rem; padding-bottom: 3rem; max-width: 720px;">
    <div class="card">
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" style="color:#fca5a5;margin-bottom:1rem;font-size:.875rem;"></div>
                <input type="hidden" asp-for="Id" />

                <div class="search-grid sg-2 mb-4">
                    <div class="form-group">
                        <label asp-for="Brand">Hãng xe</label>
                        <input asp-for="Brand" class="form-control" />
                        <span asp-validation-for="Brand" style="color:#fca5a5;font-size:.75rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Model">Dòng xe</label>
                        <input asp-for="Model" class="form-control" />
                        <span asp-validation-for="Model" style="color:#fca5a5;font-size:.75rem;"></span>
                    </div>
                </div>

                <div class="search-grid sg-2 mb-4">
                    <div class="form-group">
                        <label asp-for="Year">Năm sản xuất</label>
                        <input asp-for="Year" class="form-control" type="number" />
                        <span asp-validation-for="Year" style="color:#fca5a5;font-size:.75rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="PricePerDay">Giá thuê / ngày (VNĐ)</label>
                        <input asp-for="PricePerDay" class="form-control" type="number" step="1000" />
                        <span asp-validation-for="PricePerDay" style="color:#fca5a5;font-size:.75rem;"></span>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label class="d-flex align-center gap-2" style="cursor:pointer;">
                        <input asp-for="IsAvailable" type="checkbox" style="width:18px;height:18px;accent-color:var(--accent);" />
                        <span style="color:var(--text);font-size:.875rem;">Xe đang còn trống</span>
                    </label>
                </div>

                <div class="d-flex gap-3" style="padding-top:1rem;border-top:1px solid var(--border);">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="btn btn-outline btn-lg">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
