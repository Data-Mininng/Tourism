@model TravelApp.Models.Car

@{
    ViewData["Title"] = "Xoá xe";
}

<div class="page-header">
    <div class="container">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
            Xác nhận xoá xe
        </h1>
        <div class="meta-row">
            <div class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                Hành động này không thể hoàn tác
            </div>
        </div>
    </div>
</div>

<div class="container" style="padding-top: 2rem; padding-bottom: 3rem; max-width: 600px;">
    <div class="card" style="border-color:rgba(239,68,68,.3);">
        <div class="card-body">
            <div style="text-align:center;margin-bottom:1.5rem;">
                <div style="width:64px;height:64px;background:rgba(239,68,68,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </div>
                <h2 class="fw-bold mb-2" style="font-size:1.25rem;">Bạn có chắc chắn muốn xoá?</h2>
                <p class="muted text-sm">Xe này sẽ bị xoá vĩnh viễn khỏi hệ thống</p>
            </div>

            <div style="background:rgba(255,255,255,.04);border-radius:8px;padding:1.25rem;margin-bottom:1.5rem;">
                <div class="d-flex align-center gap-3 mb-3">
                    <div style="width:40px;height:40px;background:rgba(16,185,129,.15);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
                    </div>
                    <div>
                        <h3 class="fw-bold" style="font-size:1rem;">@Model.Brand @Model.Model</h3>
                        <span class="muted text-xs">Mã xe: #@Model.Id</span>
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                    <div>
                        <span class="muted text-xs">Năm sản xuất</span>
                        <div class="fw-semi text-sm">@Model.Year</div>
                    </div>
                    <div>
                        <span class="muted text-xs">Giá thuê / ngày</span>
                        <div class="fw-semi text-sm accent">@Model.PricePerDay.ToString("N0")đ</div>
                    </div>
                    <div>
                        <span class="muted text-xs">Trạng thái</span>
                        <div>
                            @if (Model.IsAvailable)
                            {
                                <span class="badge badge-green">Còn trống</span>
                            }
                            else
                            {
                                <span class="badge badge-red">Đã thuê</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-lg flex-1" style="background:rgba(239,68,68,.8);color:#fff;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        Xác nhận xoá
                    </button>
                    <a asp-action="Index" class="btn btn-outline btn-lg flex-1" style="justify-content:center;">Huỷ bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>
