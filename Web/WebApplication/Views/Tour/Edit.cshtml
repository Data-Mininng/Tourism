@model Tour
@{
    ViewData["Title"] = "Chỉnh sửa tour";
}

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Chỉnh sửa <span class="accent">@Model.Name</span>
        </h1>
        <div class="meta-row">
            <div class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                @Model.Destination
            </div>
            <div class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                @Model.DurationDays ngày
            </div>
        </div>
    </div>
</div>

<div class="section">
    <div class="container" style="max-width:720px;">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="All" style="color:#fca5a5; font-size:.85rem; margin-bottom:1rem;"></div>

                    <div class="search-grid sg-2 mb-4">
                        <div class="form-group">
                            <label asp-for="Name">Tên tour <span class="accent">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="VD: Khám phá Vịnh Hạ Long" />
                            <span asp-validation-for="Name" style="color:#fca5a5; font-size:.75rem;"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Destination">Điểm đến <span class="accent">*</span></label>
                            <input asp-for="Destination" class="form-control" placeholder="VD: Quảng Ninh" />
                            <span asp-validation-for="Destination" style="color:#fca5a5; font-size:.75rem;"></span>
                        </div>
                    </div>

                    <div class="search-grid sg-2 mb-4">
                        <div class="form-group">
                            <label asp-for="DurationDays">Số ngày</label>
                            <input asp-for="DurationDays" class="form-control" type="number" min="1" placeholder="VD: 3" />
                            <span asp-validation-for="DurationDays" style="color:#fca5a5; font-size:.75rem;"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Price">Giá tour (VNĐ)</label>
                            <input asp-for="Price" class="form-control" type="number" min="0" placeholder="VD: 3500000" />
                            <span asp-validation-for="Price" style="color:#fca5a5; font-size:.75rem;"></span>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Description">Mô tả tour <span class="accent">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả chi tiết về chương trình tour..." style="resize:vertical;"></textarea>
                        <span asp-validation-for="Description" style="color:#fca5a5; font-size:.75rem;"></span>
                    </div>

                    <div class="d-flex gap-3" style="justify-content:flex-end; padding-top:1rem; border-top:1px solid var(--border);">
                        <a asp-action="Index" class="btn btn-outline">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                            Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            Cập nhật
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
