@model Tour
@{
    ViewData["Title"] = "Xóa tour";
}

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
            Xóa <span style="color:#fca5a5;">Tour</span>
        </h1>
        <div class="meta-row">
            <div class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                Hành động này không thể hoàn tác
            </div>
        </div>
    </div>
</div>

<div class="section">
    <div class="container" style="max-width:600px;">
        <div class="card" style="border-color:rgba(239,68,68,.3);">
            <div class="card-body" style="text-align:center; padding:2.5rem;">
                <!-- Warning Icon -->
                <div style="width:64px; height:64px; border-radius:50%; background:rgba(239,68,68,.15); display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                </div>

                <h2 class="fw-bold mb-2" style="font-size:1.4rem;">Xác nhận xóa tour?</h2>
                <p class="muted mb-4">Bạn có chắc chắn muốn xóa tour này không?</p>

                <!-- Tour Info Summary -->
                <div style="background:rgba(255,255,255,.04); border:1px solid var(--border); border-radius:var(--radius); padding:1.25rem; margin-bottom:1.5rem; text-align:left;">
                    <div class="d-flex align-center gap-3 mb-3">
                        <div style="width:48px; height:48px; border-radius:10px; background:rgba(16,185,129,.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                        </div>
                        <div>
                            <div class="fw-semi" style="font-size:1.05rem;">@Model.Name</div>
                            <div class="text-sm muted">@Model.Destination</div>
                        </div>
                    </div>
                    <p class="text-sm muted mb-3" style="display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                        @Model.Description
                    </p>
                    <div class="d-flex gap-3" style="flex-wrap:wrap;">
                        <span class="badge badge-amber">
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            @Model.DurationDays ngày
                        </span>
                        <span class="badge badge-green">@Model.Price.ToString("N0")đ</span>
                    </div>
                </div>

                <!-- Action Buttons -->
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-3" style="justify-content:center;">
                        <a asp-action="Index" class="btn btn-outline btn-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                            Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-lg" style="background:rgba(239,68,68,.8); color:#fff;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                            Xác nhận xóa
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
