@{
    ViewData["Title"] = "Chính Sách Bảo Mật";
}

<div class="page-header">
    <div>
        <h1 class="text-3xl fw-bold">Chính Sách Bảo Mật</h1>
        <p class="muted mt-2">Cam kết bảo vệ thông tin cá nhân của bạn</p>
    </div>
</div>

<div class="section">
    <div class="card" style="max-width:860px;">
        <div class="card-body" style="padding:2rem;">

            <!-- Intro -->
            <div class="d-flex align-center gap-3 mb-4" style="padding-bottom:1.5rem; border-bottom:1px solid var(--border);">
                <div style="width:48px; height:48px; border-radius:0.75rem; background:rgba(16,185,129,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                </div>
                <div>
                    <p>Chúng tôi cam kết bảo vệ quyền riêng tư và thông tin cá nhân của bạn. Chính sách này mô tả cách chúng tôi thu thập, sử dụng và bảo vệ dữ liệu của bạn khi sử dụng dịch vụ du lịch trực tuyến.</p>
                </div>
            </div>

            <!-- Section 1 -->
            <div class="mb-4">
                <div class="d-flex align-center gap-2 mb-3">
                    <div style="width:32px; height:32px; border-radius:0.5rem; background:rgba(59,130,246,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    </div>
                    <h2 class="text-xl fw-bold">1. Thu Thập Thông Tin</h2>
                </div>
                <div style="padding-left:2.5rem;">
                    <p class="muted mb-2">Chúng tôi thu thập các loại thông tin sau khi bạn sử dụng dịch vụ:</p>
                    <div class="tag-row" style="flex-direction:column; align-items:flex-start; gap:0.5rem;">
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Họ tên, email, số điện thoại khi đăng ký tài khoản</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Thông tin thanh toán khi đặt dịch vụ du lịch</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Lịch sử tìm kiếm và đặt chỗ trên hệ thống</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Thông tin thiết bị và trình duyệt truy cập</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 2 -->
            <div class="mb-4">
                <div class="d-flex align-center gap-2 mb-3">
                    <div style="width:32px; height:32px; border-radius:0.5rem; background:rgba(16,185,129,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    </div>
                    <h2 class="text-xl fw-bold">2. Sử Dụng Thông Tin</h2>
                </div>
                <div style="padding-left:2.5rem;">
                    <p class="muted mb-2">Thông tin của bạn được sử dụng cho các mục đích sau:</p>
                    <div class="tag-row" style="flex-direction:column; align-items:flex-start; gap:0.5rem;">
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Xử lý và xác nhận đặt chỗ du lịch</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Cung cấp hỗ trợ khách hàng và giải đáp thắc mắc</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Gửi thông báo về chương trình khuyến mãi (nếu bạn đồng ý)</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Cải thiện chất lượng dịch vụ và trải nghiệm người dùng</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 3 -->
            <div class="mb-4">
                <div class="d-flex align-center gap-2 mb-3">
                    <div style="width:32px; height:32px; border-radius:0.5rem; background:rgba(245,158,11,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                    </div>
                    <h2 class="text-xl fw-bold">3. Bảo Mật Dữ Liệu</h2>
                </div>
                <div style="padding-left:2.5rem;">
                    <p class="muted mb-2">Chúng tôi áp dụng các biện pháp bảo mật nghiêm ngặt:</p>
                    <div class="tag-row" style="flex-direction:column; align-items:flex-start; gap:0.5rem;">
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Mã hóa SSL/TLS cho toàn bộ kết nối</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Mã hóa dữ liệu nhạy cảm trong cơ sở dữ liệu</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Kiểm tra bảo mật định kỳ và cập nhật hệ thống</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Giới hạn quyền truy cập dữ liệu cho nhân viên</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 4 -->
            <div class="mb-4">
                <div class="d-flex align-center gap-2 mb-3">
                    <div style="width:32px; height:32px; border-radius:0.5rem; background:rgba(239,68,68,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    </div>
                    <h2 class="text-xl fw-bold">4. Quyền Của Bạn</h2>
                </div>
                <div style="padding-left:2.5rem;">
                    <p class="muted mb-2">Bạn có các quyền sau đối với dữ liệu cá nhân:</p>
                    <div class="tag-row" style="flex-direction:column; align-items:flex-start; gap:0.5rem;">
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Quyền truy cập và xem thông tin cá nhân đã cung cấp</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Quyền yêu cầu chỉnh sửa hoặc cập nhật thông tin</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Quyền yêu cầu xóa dữ liệu cá nhân</span>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <span class="accent">•</span>
                            <span>Quyền từ chối nhận thông tin tiếp thị</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact -->
            <div style="background:rgba(16,185,129,0.08); border-radius:0.75rem; padding:1.5rem; border:1px solid rgba(16,185,129,0.2);">
                <div class="d-flex align-center gap-2 mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                    <h3 class="fw-bold">Liên Hệ Về Bảo Mật</h3>
                </div>
                <p class="text-sm muted mb-2">Nếu bạn có bất kỳ câu hỏi nào về chính sách bảo mật, vui lòng liên hệ:</p>
                <div class="d-flex gap-4" style="flex-wrap:wrap;">
                    <div class="d-flex align-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                        <span class="text-sm accent">privacy&#64;travelapp.vn</span>
                    </div>
                    <div class="d-flex align-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                        <span class="text-sm">1900 xxxx</span>
                    </div>
                </div>
            </div>

            <!-- Last Updated -->
            <div style="text-align:center; margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--border);">
                <p class="text-xs muted">Cập nhật lần cuối: Tháng 6, 2026</p>
            </div>
        </div>
    </div>
</div>
