@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Section -->
<section class="hero">
    <div class="hero-glow hero-glow-1"></div>
    <div class="hero-glow hero-glow-2"></div>
    <div class="container">
        <h1>Khám Phá <span class="accent">Việt Nam</span> Tuyệt Đẹp</h1>
        <p>Tìm vé máy bay, khách sạn, tour du lịch và dịch vụ đưa đón với giá tốt nhất.</p>

        <!-- Search Widget -->
        <div class="search-widget">
            <div class="search-tabs">
                <button class="search-tab active" onclick="switchTab('flight', this)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
                    Chuyến bay
                </button>
                <button class="search-tab" onclick="switchTab('hotel', this)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V7a2 2 0 012-2h14a2 2 0 012 2v14"/><path d="M3 11h18"/><path d="M9 21V11"/></svg>
                    Khách sạn
                </button>
                <button class="search-tab" onclick="switchTab('tour', this)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 000 20 14.5 14.5 0 000-20"/><path d="M2 12h20"/></svg>
                    Tour
                </button>
                <button class="search-tab" onclick="switchTab('car', this)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 16H9m10 0h3v-3.15a1 1 0 00-.84-.99L16 11l-2.7-3.6a1 1 0 00-.8-.4H5.24a2 2 0 00-1.8 1.1l-.8 1.63A6 6 0 002 12.42V16h2"/><circle cx="6.5" cy="16.5" r="2.5"/><circle cx="16.5" cy="16.5" r="2.5"/></svg>
                    Thuê xe
                </button>
            </div>

            <!-- Tab: Chuyến bay -->
            <div class="tab-content active" id="tab-flight">
                <form asp-controller="Flight" asp-action="Index" method="get">
                    <div class="search-grid sg-4">
                        <div class="form-group">
                            <label>Điểm đi</label>
                            <input type="text" class="form-control" name="from" placeholder="Hồ Chí Minh (SGN)">
                        </div>
                        <div class="form-group">
                            <label>Điểm đến</label>
                            <input type="text" class="form-control" name="to" placeholder="Hà Nội (HAN)">
                        </div>
                        <div class="form-group">
                            <label>Ngày đi</label>
                            <input type="date" class="form-control" name="date">
                        </div>
                        <div class="form-group" style="display:flex; align-items:flex-end;">
                            <button type="submit" class="btn btn-primary btn-full">Tìm chuyến bay</button>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Tab: Khách sạn -->
            <div class="tab-content" id="tab-hotel">
                <form asp-controller="Hotel" asp-action="Index" method="get">
                    <div class="search-grid sg-4">
                        <div class="form-group">
                            <label>Địa điểm</label>
                            <input type="text" class="form-control" name="location" placeholder="Đà Nẵng">
                        </div>
                        <div class="form-group">
                            <label>Ngày nhận phòng</label>
                            <input type="date" class="form-control" name="checkin">
                        </div>
                        <div class="form-group">
                            <label>Ngày trả phòng</label>
                            <input type="date" class="form-control" name="checkout">
                        </div>
                        <div class="form-group" style="display:flex; align-items:flex-end;">
                            <button type="submit" class="btn btn-primary btn-full">Tìm khách sạn</button>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Tab: Tour -->
            <div class="tab-content" id="tab-tour">
                <form asp-controller="Tour" asp-action="Index" method="get">
                    <div class="search-grid sg-3">
                        <div class="form-group">
                            <label>Điểm đến</label>
                            <input type="text" class="form-control" name="destination" placeholder="Hạ Long, Sapa...">
                        </div>
                        <div class="form-group">
                            <label>Số ngày</label>
                            <input type="number" class="form-control" name="days" placeholder="3" min="1">
                        </div>
                        <div class="form-group" style="display:flex; align-items:flex-end;">
                            <button type="submit" class="btn btn-primary btn-full">Tìm Tour</button>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Tab: Thuê xe -->
            <div class="tab-content" id="tab-car">
                <form asp-controller="Car" asp-action="Index" method="get">
                    <div class="search-grid sg-3">
                        <div class="form-group">
                            <label>Hãng xe</label>
                            <input type="text" class="form-control" name="brand" placeholder="Toyota, Honda...">
                        </div>
                        <div class="form-group">
                            <label>Ngày thuê</label>
                            <input type="date" class="form-control" name="date">
                        </div>
                        <div class="form-group" style="display:flex; align-items:flex-end;">
                            <button type="submit" class="btn btn-primary btn-full">Tìm xe</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Popular Destinations -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <h2>Điểm Đến <span class="accent">Phổ Biến</span></h2>
            <p>Khám phá những địa danh nổi tiếng nhất Việt Nam</p>
        </div>

        <div class="dest-grid">
            <!-- Nha Trang -->
            <div class="dest-card">
                <div class="img-wrap">
                    <img src="https://images.unsplash.com/photo-1540202404-a2f29016b523?q=80&w=800" alt="Nha Trang">
                    <div class="img-overlay"></div>
                    <span class="dest-badge">🏖️ Biển</span>
                </div>
                <div class="dest-content">
                    <div class="rating-row">
                        <div class="stars">
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        </div>
                        <span class="text-sm muted">4.8/5</span>
                    </div>
                    <h3 class="fw-semi mb-2">Nha Trang</h3>
                    <p class="text-sm muted mb-3">Biển xanh, cát trắng, nắng vàng. Thiên đường nghỉ dưỡng miền Trung.</p>
                    <div class="dest-footer">
                        <div>
                            <span class="price-big">2.5tr</span>
                            <span class="price-sub"> /người</span>
                        </div>
                        <a asp-controller="Tour" asp-action="Index" class="btn btn-primary">Xem Tour</a>
                    </div>
                </div>
            </div>

            <!-- Đà Nẵng -->
            <div class="dest-card">
                <div class="img-wrap">
                    <img src="https://images.unsplash.com/photo-1564236236216-06f3c6b3c36a?q=80&w=800" alt="Đà Nẵng">
                    <div class="img-overlay"></div>
                    <span class="dest-badge">🌉 Thành phố</span>
                </div>
                <div class="dest-content">
                    <div class="rating-row">
                        <div class="stars">
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        </div>
                        <span class="text-sm muted">4.6/5</span>
                    </div>
                    <h3 class="fw-semi mb-2">Đà Nẵng</h3>
                    <p class="text-sm muted mb-3">Thành phố đáng sống, Cầu Vàng và biển Mỹ Khê tuyệt đẹp.</p>
                    <div class="dest-footer">
                        <div>
                            <span class="price-big">3.2tr</span>
                            <span class="price-sub"> /người</span>
                        </div>
                        <a asp-controller="Tour" asp-action="Index" class="btn btn-primary">Xem Tour</a>
                    </div>
                </div>
            </div>

            <!-- Hạ Long -->
            <div class="dest-card">
                <div class="img-wrap">
                    <img src="https://images.unsplash.com/photo-1592748669748-45d5f79bdf0b?q=80&w=800" alt="Hạ Long">
                    <div class="img-overlay"></div>
                    <span class="dest-badge">🛥️ Di sản</span>
                </div>
                <div class="dest-content">
                    <div class="rating-row">
                        <div class="stars">
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <svg class="star filled" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        </div>
                        <span class="text-sm muted">4.9/5</span>
                    </div>
                    <h3 class="fw-semi mb-2">Vịnh Hạ Long</h3>
                    <p class="text-sm muted mb-3">Di sản thiên nhiên thế giới UNESCO, du thuyền và hang động kỳ vĩ.</p>
                    <div class="dest-footer">
                        <div>
                            <span class="price-big">4.0tr</span>
                            <span class="price-sub"> /người</span>
                        </div>
                        <a asp-controller="Tour" asp-action="Index" class="btn btn-primary">Xem Tour</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="section" style="background: linear-gradient(to bottom, rgba(16,185,129,.03), transparent);">
    <div class="container">
        <div class="section-header">
            <h2>Tại Sao Chọn <span class="accent">Chúng Tôi</span>?</h2>
            <p>Cam kết mang đến trải nghiệm du lịch tốt nhất</p>
        </div>
        <div class="features-row">
            <div class="feature-item">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h3>An Toàn</h3>
                <p class="text-sm muted">Đảm bảo an toàn tuyệt đối cho mọi chuyến đi</p>
            </div>
            <div class="feature-item">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                </div>
                <h3>Giá Tốt</h3>
                <p class="text-sm muted">Cam kết giá tốt nhất thị trường</p>
            </div>
            <div class="feature-item">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <h3>Uy Tín</h3>
                <p class="text-sm muted">Hơn 100,000 khách hàng tin tưởng</p>
            </div>
            <div class="feature-item">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                </div>
                <h3>Hỗ trợ 24/7</h3>
                <p class="text-sm muted">Đội ngũ hỗ trợ luôn sẵn sàng</p>
            </div>
        </div>
    </div>
</section>