@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<div class="container" style="margin-top: 3rem; margin-bottom: 5rem;">
    <div style="margin-bottom: 1.5rem;">
        <a asp-controller="Admin" asp-action="Dashboard" style="color: var(--accent); text-decoration: none; font-size: 0.9rem;">&larr; Quay lại trang Dashboard Admin</a>
    </div>

    <div class="card" style="background: #111827; border: 1px solid #1f2937; border-radius: 12px; padding: 2rem; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.3);">
        <div style="border-bottom: 1px solid #1f2937; padding-bottom: 1rem; margin-bottom: 2rem; display: flex; align-items: center; gap: 0.75rem;">
            <div style="background: rgba(16, 185, 129, 0.1); color: #10b981; padding: 0.5rem 0.75rem; border-radius: 8px; font-size: 1.25rem;">
                <i class="fa-solid fa-microchip"></i>
            </div>
            <div>
                <h2 style="margin: 0; font-size: 1.5rem; font-weight: 600; color: #f9fafb;">Quản lý và Khai phá luật liên kết gợi ý AI</h2>
                <p style="margin: 0; font-size: 0.85rem; color: #9ca3af;">Điều chỉnh ngưỡng tối thiểu của thuật toán FP-Growth áp dụng trên tệp dữ liệu hành trình du lịch.</p>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 3rem;">
            <div>
                <h3 style="font-size: 1.1rem; font-weight: 500; color: #e5e7eb; margin-bottom: 1.5rem;"><i class="fa-solid fa-sliders" style="margin-right: 0.5rem; color: #10b981;"></i>Bộ cấu hình tham số</h3>

                <div style="margin-bottom: 2rem;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.95rem; font-weight: 500;">
                        <span style="color: #cbd5e1;">Độ hỗ trợ tối thiểu (Min Support):</span>
                        <span id="txtSupport" style="color: #10b981; font-weight: 700;">0.05</span>
                    </div>
                    <input type="range" id="rangeSupport" min="0.01" max="0.30" step="0.01" value="0.05" style="width: 100%; accent-color: #10b981; cursor: pointer;" oninput="syncLabels()" />
                    <span style="display: block; font-size: 0.8rem; color: #6b7280; margin-top: 0.35rem; line-height: 1.4;">
                        Tần suất xuất hiện tối thiểu của một mẫu hành vi. (Ví dụ: 0.05 yêu cầu ngữ cảnh du lịch này phải nằm trong ít nhất 5% tổng số dữ liệu lịch sử).
                    </span>
                </div>

                <div style="margin-bottom: 2.5rem;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.95rem; font-weight: 500;">
                        <span style="color: #cbd5e1;">Độ tin cậy tối thiểu (Min Confidence):</span>
                        <span id="txtConfidence" style="color: #10b981; font-weight: 700;">0.30</span>
                    </div>
                    <input type="range" id="rangeConfidence" min="0.10" max="0.90" step="0.05" value="0.30" style="width: 100%; accent-color: #10b981; cursor: pointer;" oninput="syncLabels()" />
                    <span style="display: block; font-size: 0.8rem; color: #6b7280; margin-top: 0.35rem; line-height: 1.4;">
                        Độ mạnh/tin cậy tối thiểu của hệ quả luật. (Ví dụ: 0.30 có nghĩa là khi vế điều kiện xảy ra thì ít nhất 30% hành vi tiếp theo sẽ chọn dịch vụ được gợi ý vế phải).
                    </span>
                </div>

                <button id="btnExecuteTrain" onclick="startRuleMining()" style="width: 100%; background: #10b981; color: #fff; border: none; border-radius: 8px; padding: 0.85rem 1rem; font-weight: 600; font-size: 1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem; box-shadow: 0 4px 6px -1px rgba(16, 185, 129, 0.2); transition: background 0.2s;">
                    <i class="fa-solid fa-play"></i> Thực thi sinh ma trận luật mới
                </button>
            </div>

            <div style="display: flex; flex-direction: column;">
                <h3 style="font-size: 1.1rem; font-weight: 500; color: #e5e7eb; margin-bottom: 1.5rem;"><i class="fa-solid fa-terminal" style="margin-right: 0.5rem; color: #9ca3af;"></i>Nhật ký giám sát hệ thống</h3>
                <div id="monitorConsole" style="flex-grow: 1; min-height: 250px; background: #030712; border: 1px solid #1f2937; border-radius: 8px; padding: 1.25rem; font-family: 'Courier New', Courier, monospace; font-size: 0.85rem; line-height: 1.6; color: #10b981; overflow-y: auto;">
                    <span style="color: #6b7280;">[Hệ thống] Trạng thái: Sẵn sàng nhận lệnh cấu hình khai phá dữ liệu từ Quản trị viên...</span><br>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function syncLabels() {
        document.getElementById('txtSupport').innerText = document.getElementById('rangeSupport').value;
        document.getElementById('txtConfidence').innerText = document.getElementById('rangeConfidence').value;
        }

        function startRuleMining() {
        const btn = document.getElementById('btnExecuteTrain');
        const consoleBox = document.getElementById('monitorConsole');
        const supp = parseFloat(document.getElementById('rangeSupport').value);
        const conf = parseFloat(document.getElementById('rangeConfidence').value);

        // Bật trạng thái Loading cho nút bấm
        btn.disabled = true;
        btn.style.background = '#374151';
        btn.style.cursor = 'not-allowed';
        btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Đang tính toán tập phổ biến FP-Growth...';

        consoleBox.innerHTML += `<span style="color: #fbbf24;">[Gửi lệnh] Đang đóng gói dữ liệu JSON gửi sang Python API (MinSupport: ${supp}, MinConfidence: ${conf})...</span><br>`;
        consoleBox.scrollTop = consoleBox.scrollHeight;

        $.ajax({
        url: '/Admin/ExecuteTrainRules',
        type: 'POST',
        data: { min_support: supp, min_confidence: conf },
        success: function (res) {
        if (res.status === "success") {
        consoleBox.innerHTML += `<span style="color: #10b981;">[Thành công] Python xử lý thành công!</span><br>`;
        consoleBox.innerHTML += `<span style="color: #f3f4f6;">→ Chi tiết phản hồi: ${res.message}</span><br>`;
        consoleBox.innerHTML += `<span style="color: #f3f4f6;">→ Hệ thống đã bốc tách và lưu trữ tổng cộng: <strong>${res.total_rules}</strong> luật mới xuống SQL Server bảng Luat_FPGrowth.</span><br>`;
        } else {
        consoleBox.innerHTML += `<span style="color: #ef4444;">[Thất bại] Tiến trình bị hủy bỏ do lỗi: ${res.message}</span><br>`;
        }
        },
        error: function (xhr, status, err) {
        consoleBox.innerHTML += `<span style="color: #ef4444;">[Lỗi kết nối] Không thể kết nối hoặc thiết lập luồng tới cổng C# Controller. Chi tiết: ${err}</span><br>`;
        },
        complete: function () {
        // Trả lại trạng thái ban đầu của nút bấm
        btn.disabled = false;
        btn.style.background = '#10b981';
        btn.style.cursor = 'pointer';
        btn.innerHTML = '<i class="fa-solid fa-play"></i> Thực thi sinh ma trận luật mới';
        consoleBox.innerHTML += `<span style="color: #6b7280;">----------------------------------------------------------------------</span><br>`;
        consoleBox.scrollTop = consoleBox.scrollHeight;
        }
        });
        }
    </script>
}