@{
    ViewData["Title"] = "Quản trị hệ thống";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex" style="justify-content:space-between; align-items:center;">
            <div>
                <h1>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
                    Dashboard Quản Trị
                </h1>
                <p class="muted mt-2">Tổng quan hệ thống Vietnam Travel</p>
            </div>
            <span class="badge badge-red" style="font-size:0.85rem; padding:0.4rem 1rem;">Quyền: Admin</span>
        </div>
    </div>
</div>

<div class="container py-4">
    <!-- Stats Grid -->
    <div class="stats-grid" style="grid-template-columns: repeat(4, 1fr);">
        <div class="stat-card">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <div class="stat-value">@ViewBag.UserCount</div>
            <div class="stat-label">Người dùng</div>
        </div>
        <div class="stat-card">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <div class="stat-value" style="color:#3b82f6;">@ViewBag.BookingCount</div>
            <div class="stat-label">Đặt chỗ</div>
        </div>
        <div class="stat-card">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2"><path d="M14 16H9m10 0h3v-3.15a1 1 0 00-.84-.99L16 11l-2.7-3.6a2 2 0 00-1.6-.8H5a2 2 0 00-2 2v7h2m4 0h6m4 0a2 2 0 11-4 0 2 2 0 014 0zM7 16a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            <div class="stat-value" style="color:#f59e0b;">@ViewBag.CarCount</div>
            <div class="stat-label">Xe</div>
        </div>
        <div class="stat-card">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
            <div class="stat-value" style="color:#ef4444;">@ViewBag.FlightCount</div>
            <div class="stat-label">Chuyến bay</div>
        </div>
    </div>

    <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr); margin-top:1rem;">
        <div class="stat-card">
            <div class="stat-value" style="color:#8b5cf6;">@ViewBag.HotelCount</div>
            <div class="stat-label">Khách sạn</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:#06b6d4;">@ViewBag.TourCount</div>
            <div class="stat-label">Tour</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:#84cc16;">@ViewBag.TransferCount</div>
            <div class="stat-label">Đưa đón</div>
        </div>
    </div>

    <!-- Menu Quản lý -->
    <h3 class="fw-bold mt-6 mb-3">Menu Quản lý</h3>
    <div class="search-grid sg-3">
        <a href="/Admin/ManageBookings" class="card" style="text-decoration:none; border:2px solid var(--accent); background:rgba(16,185,129,0.05);">
            <div class="card-body d-flex align-center gap-3">
                <span style="font-size:1.5rem;">📋</span>
                <div>
                    <div class="fw-semi" style="color:var(--accent);">Quản lý Đơn Đặt (Bookings)</div>
                    <div class="text-xs muted">Duyệt hoặc từ chối đơn hàng</div>
                </div>
            </div>
        </a>
        <a href="/Car/Index" class="card" style="text-decoration:none;">
            <div class="card-body d-flex align-center gap-3">
                <span style="font-size:1.5rem;">🚗</span>
                <div>
                    <div class="fw-semi">Quản lý Xe</div>
                    <div class="text-xs muted">Thêm / Sửa / Xóa xe</div>
                </div>
            </div>
        </a>
        <a href="/Flight/Index" class="card" style="text-decoration:none;">
            <div class="card-body d-flex align-center gap-3">
                <span style="font-size:1.5rem;">✈️</span>
                <div>
                    <div class="fw-semi">Quản lý Chuyến bay</div>
                    <div class="text-xs muted">Thêm / Sửa / Xóa chuyến bay</div>
                </div>
            </div>
        </a>
        <a href="/Hotel/Index" class="card" style="text-decoration:none;">
            <div class="card-body d-flex align-center gap-3">
                <span style="font-size:1.5rem;">🏨</span>
                <div>
                    <div class="fw-semi">Quản lý Khách sạn</div>
                    <div class="text-xs muted">Thêm / Sửa / Xóa khách sạn</div>
                </div>
            </div>
        </a>
        <a href="/Tour/Index" class="card" style="text-decoration:none;">
            <div class="card-body d-flex align-center gap-3">
                <span style="font-size:1.5rem;">🗺️</span>
                <div>
                    <div class="fw-semi">Quản lý Tour</div>
                    <div class="text-xs muted">Thêm / Sửa / Xóa tour</div>
                </div>
            </div>
        </a>
        <a href="/Transfer/Index" class="card" style="text-decoration:none;">
            <div class="card-body d-flex align-center gap-3">
                <span style="font-size:1.5rem;">🚌</span>
                <div>
                    <div class="fw-semi">Quản lý Đưa đón</div>
                    <div class="text-xs muted">Thêm / Sửa / Xóa phương tiện</div>
                </div>
            </div>
        </a>
    </div>
</div>