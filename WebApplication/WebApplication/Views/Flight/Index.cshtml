@model IEnumerable<TravelApp.Models.Flight>
@{
    ViewData["Title"] = "Kết quả tìm chuyến bay";
}

<div class="page-header">
    <div class="container">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
            Kết quả tìm chuyến bay
        </h1>
        <div class="meta-row">
            <div class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                15/07/2026
            </div>
            <div class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                1 Người lớn
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="results-layout">
        <!-- Sidebar Filter -->
        <div class="filter-panel">
            <h3>Bộ lọc</h3>
            
            <div class="filter-group">
                <h4>Hãng hàng không</h4>
                <label class="check-row">
                    <input type="checkbox" checked>
                    <span>Vietnam Airlines</span>
                </label>
                <label class="check-row">
                    <input type="checkbox" checked>
                    <span>Vietjet Air</span>
                </label>
                <label class="check-row">
                    <input type="checkbox" checked>
                    <span>Bamboo Airways</span>
                </label>
            </div>

            <div class="filter-group">
                <div class="sep"></div>
                <h4>Thời gian bay</h4>
                <label class="check-row">
                    <input type="checkbox">
                    <span>Sáng (00:00 - 11:59)</span>
                </label>
                <label class="check-row">
                    <input type="checkbox">
                    <span>Chiều (12:00 - 17:59)</span>
                </label>
                <label class="check-row">
                    <input type="checkbox">
                    <span>Tối (18:00 - 23:59)</span>
                </label>
            </div>
        </div>

        <!-- Kết quả -->
        <div class="results-list">
            @if (!Model.Any())
            {
                <div class="card" style="text-align:center; padding:3rem;">
                    <p class="muted">Không tìm thấy chuyến bay nào.</p>
                </div>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <div class="flight-card">
                        <div class="flight-inner">
                            <div style="flex:1;">
                                <div class="airline-name">@item.Airline</div>
                                <div class="text-xs muted2">Chuyến bay @item.FlightNumber</div>
                            </div>

                            <div class="flight-times">
                                <div style="text-align:right;">
                                    <div class="time-big">@item.DepartureTime.ToString("HH:mm")</div>
                                    <div class="airport-code">@item.Departure</div>
                                </div>

                                <div class="flight-mid">
                                    <div class="text-xs muted mb-2">@((item.ArrivalTime - item.DepartureTime).ToString(@"h\h\ m\m"))</div>
                                    <div class="flight-line">
                                        <div class="line-seg"></div>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
                                        <div class="line-seg rev"></div>
                                    </div>
                                    <div class="text-xs muted mt-2">Bay thẳng</div>
                                </div>

                                <div style="text-align:left;">
                                    <div class="time-big">@item.ArrivalTime.ToString("HH:mm")</div>
                                    <div class="airport-code">@item.Arrival</div>
                                </div>
                            </div>

                            <div class="flight-right">
                                <div style="text-align:right;">
                                    <div class="price-big">@item.Price.ToString("N0") ₫</div>
                                    <div class="price-sub">/ khách</div>
                                </div>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary">Chọn vé</a>
                                <div class="text-xs muted2 mt-2">Còn @item.AvailableSeats chỗ</div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>