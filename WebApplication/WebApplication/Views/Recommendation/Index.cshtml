@model TravelApp.Controllers.RecommendationViewModel
@{
    ViewData["Title"] = "Dành cho bạn";
    var voucher = ViewBag.ActiveVoucher as TravelApp.Models.VoucherIssued;
}

<div class="page-header">
    <div class="container">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            Dành cho <span class="accent">Bạn</span>
        </h1>
        <p class="muted mt-2">Gợi ý cá nhân hóa dựa trên hành trình bạn đang khám phá</p>
    </div>
</div>

<div class="section pt-4">
    <div class="container">

        @* Voucher đang hoạt động *@
        @if (voucher != null)
        {
            <div style="
                background:rgba(245,158,11,.1); border:1px solid rgba(245,158,11,.4);
                border-radius:12px; padding:1.25rem 1.5rem; margin-bottom:2rem;
                display:flex; align-items:center; gap:1rem; flex-wrap:wrap;
            ">
                <span style="font-size:1.6rem;">🎁</span>
                <div style="flex:1;">
                    <div style="font-weight:700; color:#f59e0b;">
                        Bạn đang có voucher: <span style="font-family:monospace; letter-spacing:.1em;">@voucher.VoucherCode</span>
                    </div>
                    <div class="text-sm muted">
                        Giảm <strong>@voucher.DiscountPercent%</strong> cho @voucher.ApplicableType
                        &nbsp;·&nbsp; Hết hạn lúc @voucher.ExpiresAt.ToString("HH:mm dd/MM")
                    </div>
                </div>
            </div>
        }

        @* Gợi ý luật kết hợp - JS render vào đây *@
        <div id="rec-assoc-block" style="display:none; margin-bottom:2.5rem;">
            <div class="d-flex align-center gap-2 mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
                <h2 class="fw-semi text-xl" style="margin:0;">Gói dịch vụ được đề xuất</h2>
                <span style="font-size:.7rem;font-weight:700;padding:.2rem .55rem;
                    background:rgba(245,158,11,.15);color:#f59e0b;
                    border-radius:999px;border:1px solid rgba(245,158,11,.3);">
                    Dựa trên hành vi của bạn
                </span>
            </div>
            <div id="rec-assoc-cards" style="display:flex;gap:1rem;flex-wrap:wrap;"></div>
        </div>

        @* Banner nếu chưa có lịch sử *@
        @if (!Model.RecentPageTypes.Any())
        {
            <div class="card mb-4" style="text-align:center;padding:2.5rem;border:1px dashed var(--border);">
                <div style="font-size:2.8rem;margin-bottom:.75rem;">🧭</div>
                <p class="fw-semi mb-1">Bắt đầu khám phá để nhận gợi ý cá nhân!</p>
                <p class="muted text-sm mb-3">Xem qua tour, khách sạn, chuyến bay... hệ thống sẽ tự gợi ý phù hợp.</p>
                <div style="display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap;">
                    <a asp-controller="Tour"     asp-action="Index" class="btn btn-outline" style="font-size:.85rem;">🗺️ Tour</a>
                    <a asp-controller="Hotel"    asp-action="Index" class="btn btn-outline" style="font-size:.85rem;">🏨 Khách sạn</a>
                    <a asp-controller="Flight"   asp-action="Index" class="btn btn-outline" style="font-size:.85rem;">✈️ Chuyến bay</a>
                    <a asp-controller="Car"      asp-action="Index" class="btn btn-outline" style="font-size:.85rem;">🚙 Thuê xe</a>
                    <a asp-controller="Transfer" asp-action="Index" class="btn btn-outline" style="font-size:.85rem;">🚗 Đưa đón</a>
                </div>
            </div>
        }

        @* Tour *@
        @if (Model.SuggestedTours.Any())
        {
            <div class="mb-5">
                <div class="d-flex align-center gap-2 mb-3">
                    <span style="font-size:1.2rem;">🗺️</span>
                    <h2 class="fw-semi text-xl" style="margin:0;">Tour phù hợp với bạn</h2>
                </div>
                <div class="dest-grid">
                    @foreach (var t in Model.SuggestedTours)
                    {
                        <div class="dest-card">
                            <div class="img-wrap">
                                <img src="https://images.unsplash.com/photo-1528127269322-539801943592?q=80&w=800" alt="@t.Name">
                                <div class="img-overlay"></div>
                                <span class="dest-badge">@t.DurationDays Ngày</span>
                            </div>
                            <div class="dest-content">
                                <h3 class="fw-semi mb-2" style="font-size:1rem;height:48px;overflow:hidden;">@t.Name</h3>
                                <p class="text-sm muted mb-3" style="height:36px;overflow:hidden;">@t.Description</p>
                                <div class="dest-footer">
                                    <div>
                                        <span class="price-big" style="font-size:1rem;">@t.Price.ToString("N0") ₫</span>
                                        <span class="price-sub">/ người</span>
                                    </div>
                                    <a asp-controller="Tour" asp-action="Details" asp-route-id="@t.Id"
                                       class="btn btn-outline" style="padding:.35rem .9rem;font-size:.8rem;">Xem</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* Hotel *@
        @if (Model.SuggestedHotels.Any())
        {
            <div class="mb-5">
                <div class="d-flex align-center gap-2 mb-3">
                    <span style="font-size:1.2rem;">🏨</span>
                    <h2 class="fw-semi text-xl" style="margin:0;">Khách sạn bạn có thể thích</h2>
                </div>
                <div class="dest-grid">
                    @foreach (var h in Model.SuggestedHotels)
                    {
                        <div class="dest-card">
                            <div class="img-wrap">
                                <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=800" alt="@h.Name">
                                <div class="img-overlay"></div>
                                <span class="dest-badge">@h.Stars ⭐</span>
                            </div>
                            <div class="dest-content">
                                <h3 class="fw-semi mb-1" style="font-size:1rem;">@h.Name</h3>
                                <p class="text-sm muted mb-3">📍 @h.Location</p>
                                <div class="dest-footer">
                                    <div>
                                        <span class="price-big" style="font-size:1rem;">@h.PricePerNight.ToString("N0") ₫</span>
                                        <span class="price-sub">/ đêm</span>
                                    </div>
                                    <a asp-controller="Hotel" asp-action="Details" asp-route-id="@h.Id"
                                       class="btn btn-outline" style="padding:.35rem .9rem;font-size:.8rem;">Xem</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* Flight *@
        @if (Model.SuggestedFlights.Any())
        {
            <div class="mb-5">
                <div class="d-flex align-center gap-2 mb-3">
                    <span style="font-size:1.2rem;">✈️</span>
                    <h2 class="fw-semi text-xl" style="margin:0;">Chuyến bay phù hợp</h2>
                </div>
                <div style="display:grid;gap:.75rem;">
                    @foreach (var f in Model.SuggestedFlights)
                    {
                        <div class="card" style="padding:1.1rem 1.25rem;">
                            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;">
                                <div>
                                    <div class="fw-semi">@f.Airline — @f.Departure → @f.Arrival</div>
                                    <div class="text-sm muted mt-1">@f.DepartureTime.ToString("HH:mm · dd/MM/yyyy")</div>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem;">
                                    <span class="price-big" style="font-size:1rem;">@f.Price.ToString("N0") ₫</span>
                                    <a asp-controller="Flight" asp-action="Details" asp-route-id="@f.Id"
                                       class="btn btn-outline" style="padding:.35rem .9rem;font-size:.8rem;">Xem</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* Car *@
        @if (Model.SuggestedCars.Any())
        {
            <div class="mb-5">
                <div class="d-flex align-center gap-2 mb-3">
                    <span style="font-size:1.2rem;">🚙</span>
                    <h2 class="fw-semi text-xl" style="margin:0;">Xe thuê còn trống</h2>
                </div>
                <div style="display:grid;gap:.75rem;">
                    @foreach (var c in Model.SuggestedCars)
                    {
                        <div class="card" style="padding:1.1rem 1.25rem;">
                            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;">
                                <div>
                                    <div class="fw-semi">@c.Brand @c.Model <span class="muted text-sm">(@c.Year)</span></div>
                                    <span class="badge badge-green" style="font-size:.7rem;margin-top:.25rem;">Còn trống</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem;">
                                    <span class="price-big" style="font-size:1rem;">@c.PricePerDay.ToString("N0") ₫/ngày</span>
                                    <a asp-controller="Car" asp-action="Details" asp-route-id="@c.Id"
                                       class="btn btn-outline" style="padding:.35rem .9rem;font-size:.8rem;">Xem</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* Transfer *@
        @if (Model.SuggestedTransfers.Any())
        {
            <div class="mb-5">
                <div class="d-flex align-center gap-2 mb-3">
                    <span style="font-size:1.2rem;">🚐</span>
                    <h2 class="fw-semi text-xl" style="margin:0;">Đưa đón sân bay</h2>
                </div>
                <div style="display:grid;gap:.75rem;">
                    @foreach (var tr in Model.SuggestedTransfers)
                    {
                        <div class="card" style="padding:1.1rem 1.25rem;">
                            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;">
                                <div>
                                    <div class="fw-semi">@tr.FromLocation → @tr.ToLocation</div>
                                    <div class="text-sm muted mt-1">@tr.Type · @tr.DepartureTime.ToString("HH:mm dd/MM")</div>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem;">
                                    <span class="price-big" style="font-size:1rem;">@tr.Price.ToString("N0") ₫</span>
                                    <a asp-controller="Transfer" asp-action="Details" asp-route-id="@tr.Id"
                                       class="btn btn-outline" style="padding:.35rem .9rem;font-size:.8rem;">Xem</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
<script>
(async function loadRecommendationSuggestions() {
    const visited = JSON.parse(sessionStorage.getItem('vt_visited_services') || '[]');
    if (!visited.length) return;

    try {
        const res  = await fetch('/Recommendation/GetSuggestions?services='
                                 + encodeURIComponent(visited.join(',')) + '&limit=5');
        const json = await res.json();
        if (json.status !== 'success' || !json.data.length) return;

        const block = document.getElementById('rec-assoc-block');
        const cards = document.getElementById('rec-assoc-cards');
        block.style.display = 'block';

        json.data.forEach(rule => {
            (rule.displayItems || []).forEach(item => {
                const icon = item.icon || '📦';
                const name = item.name || item[0] || '';
                const url  = item.url  || item[1] || '/';
                const conf = rule.do_Tin_Cay || 0;

                const card = document.createElement('a');
                card.href = url;
                card.style.cssText = `
                    display:inline-flex;align-items:center;gap:.75rem;
                    background:rgba(255,255,255,.05);
                    border:1px solid var(--border);border-radius:10px;
                    padding:.85rem 1.25rem;text-decoration:none;color:inherit;
                    transition:border-color .2s,background .2s;min-width:160px;
                `;
                card.onmouseenter = () => {
                    card.style.borderColor = 'var(--accent)';
                    card.style.background  = 'rgba(16,185,129,.08)';
                };
                card.onmouseleave = () => {
                    card.style.borderColor = 'var(--border)';
                    card.style.background  = 'rgba(255,255,255,.05)';
                };
                card.innerHTML = `
                    <span style="font-size:1.5rem;line-height:1;">${icon}</span>
                    <div>
                        <div style="font-weight:600;font-size:.9rem;">${name}</div>
                        <div style="font-size:.72rem;color:rgba(255,255,255,.5);">
                            Tin cậy <strong style="color:var(--accent);">${conf}%</strong>
                        </div>
                    </div>`;
                cards.appendChild(card);
            });
        });
    } catch(e) { /* silent */ }
})();
</script>
}
