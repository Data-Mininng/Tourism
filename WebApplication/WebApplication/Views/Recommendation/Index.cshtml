            },
            'DV_Thue_Xe_Tu_Lai': { 'default': 'https://images.unsplash.com/photo-1449965408869-eaa3f722e40d?q=80&w=400' },
            'DV_Dua_Don_San_Bay': { 'default': 'https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?q=80&w=400' },
            'HD_Tam_Bien': {
                'Nha_Trang': 'https://images.unsplash.com/photo-1540202404-a2f29016b523?q=80&w=400',
                'Phu_Quoc': 'https://images.unsplash.com/photo-1519046904884-53103b34b206?q=80&w=400',
                'default': 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=400',
            },
            'HD_Leo_Nui_Trekking': {
                'Sa_Pa': 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?q=80&w=400',
                'default': 'https://images.unsplash.com/photo-1454496522488-7a8e488e8606?q=80&w=400',
            },
            'HD_Tham_Quan_Di_Tich': {
                'Ha_Noi': 'https://images.unsplash.com/photo-1509030450996-dd1a26dda07a?q=80&w=400',
                'Hoi_An': 'https://images.unsplash.com/photo-1528360983277-13d401cdc186?q=80&w=400',
