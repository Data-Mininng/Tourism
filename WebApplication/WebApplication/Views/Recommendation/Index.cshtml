            },
            'HD_Check_In': { 'default': 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?q=80&w=400' },
            'HD_Nghi_Duong_Chua_Lanh': {
                'Da_Lat': 'https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?q=80&w=400',
                'Phu_Quoc': 'https://images.unsplash.com/photo-1571003123894-1f0594d2b5d9?q=80&w=400',
                'default': 'https://images.unsplash.com/photo-1540555700478-4be289fbecef?q=80&w=400',
            },
        };

        function getServiceImage(serviceKey, destinations) {
            const imgMap = SERVICE_IMAGES[serviceKey];
            if (!imgMap) return 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?q=80&w=400';
            if (destinations?.length) for (const d of destinations) if (imgMap[d]) return imgMap[d];
            return imgMap['default'] || 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?q=80&w=400';
        }

        const items = (document.body.dataset.allItems || sessionStorage.getItem('vt_items') || '').trim();
        if (!items) return;

        try {
            const res  = await fetch('/Recommendation/GetSuggestions?services=' + encodeURIComponent(items) + '&limit=5');
            const json = await res.json();
            if (json.status !== 'success' || !json.data?.length) return;

            const block = document.getElementById('rec-assoc-block');
            const cards = document.getElementById('rec-assoc-cards');
            const label = document.getElementById('rec-context-label');
            block.style.display = 'block';

            // Ngữ cảnh tóm tắt
            const ctxParts = items.split(',')
                .filter(s => s.startsWith('Den_') || s.startsWith('Hang_'))
                .map(s => s.replace('Den_','').replace('Hang_','').replace(/_/g,' '))
                .slice(0,3);
            if (ctxParts.length) label.textContent = 'Dựa trên: ' + ctxParts.join(' · ');

            const rendered = new Set();
            json.data.forEach(rule => {
                const destinations = rule.extractedContext?.destinations || [];
                const locationHint = rule.displayItems?.[0]?.locationHint || (destinations[0]?.replace(/_/g,' ') || '');

                (rule.displayItems || []).forEach(item => {
                    const key  = item.name || '';
                    if (rendered.has(key)) return;
                    rendered.add(key);

                    const icon      = item.icon  || '📦';
                    const url       = item.url   || '/';
                    const serviceKey = item.serviceKey || '';
                    const conf      = rule.do_Tin_Cay || 0;
                    const lift      = rule.chi_So_Lift || 1;
                    const reason    = rule.lyDoGoiY || '';
                    const imgSrc    = getServiceImage(serviceKey, destinations);
                    const locLabel  = item.locationHint || locationHint;

                    const card = document.createElement('a');
                    card.href = url;
                    card.style.cssText = `
                        display:flex;align-items:stretch;gap:0;overflow:hidden;
                        background:rgba(255,255,255,.05);border:1px solid var(--border);
                        border-radius:14px;text-decoration:none;
                        color:inherit;transition:border-color .2s,background .2s;
                        width:240px;cursor:pointer;`;
                    card.onmouseenter = () => { card.style.borderColor='var(--accent)'; card.style.background='rgba(16,185,129,.08)'; };
                    card.onmouseleave = () => { card.style.borderColor='var(--border)'; card.style.background='rgba(255,255,255,.05)'; };
                    card.innerHTML = `
                        <div style="width:80px;flex-shrink:0;overflow:hidden;">
                            <img src="${imgSrc}" alt="${key}"
                                style="width:100%;height:100%;object-fit:cover;min-height:90px;"
                                onerror="this.parentElement.innerHTML='<div style=\\'background:rgba(255,255,255,.08);width:80px;height:90px;display:flex;align-items:center;justify-content:center;font-size:2rem;\\'>${icon}</div>'">
                        </div>
                        <div style="padding:.8rem 1rem;flex:1;min-width:0;">
                            <div style="font-weight:600;font-size:.88rem;">${key}</div>
                            ${locLabel ? `<div style="font-size:.68rem;color:#6ee7b7;margin-top:.15rem;">📍 ${locLabel}</div>` : ''}
                            <div style="font-size:.67rem;color:rgba(255,255,255,.45);margin-top:.2rem;line-height:1.4;">
                                Tin cậy <strong style="color:var(--accent);">${conf}%</strong>
                                ${lift > 1.2 ? ` · Lift <strong style="color:#f59e0b;">${lift}x</strong>` : ''}
                                ${reason ? `<br><span style="font-size:.63rem;">${reason}</span>` : ''}
                            </div>
                        </div>`;
                    cards.appendChild(card);
                });
            });

            if (!cards.children.length) block.style.display = 'none';
        } catch(_) {}
    })();
    </script>
}
