@model List<TravelApp.Models.VoucherIssued>
@{
    ViewData["Title"] = "Voucher của tôi";
    var now = DateTime.Now;
    var active  = Model.Where(v => !v.IsUsed && v.ExpiresAt > now).ToList();
    var expired = Model.Where(v => v.IsUsed || v.ExpiresAt <= now).ToList();
}

<div class="page-header">
    <div class="container">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/>
                <path d="M13 5v14M9 9h1M9 12h1M9 15h1"/>
            </svg>
            Voucher của <span class="accent">Bạn</span>
        </h1>
        <p class="muted mt-2">Các ưu đãi AI đã tặng riêng cho bạn dựa trên hành vi duyệt web</p>
    </div>
</div>

<div class="section pt-4">
    <div class="container" style="max-width:860px;">

        @* Nút Test Voucher *@
        <div style="
            background:rgba(16,185,129,.07);border:1px dashed rgba(16,185,129,.4);
            border-radius:12px;padding:1.1rem 1.4rem;margin-bottom:2rem;
            display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
            <div>
                <div style="font-weight:600;font-size:.95rem;">🧪 Chế độ Test</div>
                <div class="muted text-sm">Nhấn để xem luồng cấp voucher hoạt động như thế nào (không cần đợi)</div>
            </div>
            <button id="btn-test-voucher" onclick="testVoucher()"
                style="padding:.55rem 1.3rem;background:var(--accent);color:#000;
                    border:none;border-radius:8px;font-weight:700;cursor:pointer;
                    font-size:.88rem;white-space:nowrap;">
                ⚡ Test Voucher ngay
            </button>
        </div>

        @* Kết quả test (ẩn ban đầu) *@
        <div id="test-result" style="display:none;margin-bottom:2rem;"></div>

        @* Voucher đang hoạt động *@
        <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:1rem;display:flex;align-items:center;gap:.6rem;">
            <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#10b981;box-shadow:0 0 6px #10b981;"></span>
            Đang hoạt động
            <span style="font-size:.72rem;font-weight:700;padding:.2rem .55rem;
                background:rgba(16,185,129,.15);color:#10b981;
                border-radius:999px;border:1px solid rgba(16,185,129,.3);">
                @active.Count
            </span>
        </h2>

        @if (!active.Any())
        {
            <div class="card mb-5" style="text-align:center;padding:2.5rem;border:1px dashed var(--border);">
                <div style="font-size:2.5rem;margin-bottom:.75rem;">🎫</div>
                <p class="fw-semi mb-1">Bạn chưa có voucher nào đang hoạt động</p>
                <p class="muted text-sm mb-3">Duyệt xem dịch vụ nhiều hơn, AI sẽ tự động tặng voucher phù hợp!</p>
                <a asp-controller="Recommendation" asp-action="Index" class="btn btn-outline" style="font-size:.85rem;">
                    ✨ Xem gợi ý dành cho bạn
                </a>
            </div>
        }
        else
        {
            <div style="display:grid;gap:1rem;margin-bottom:2.5rem;">
                @foreach (var v in active)
                {
                    var minutesLeft = (int)(v.ExpiresAt - now).TotalMinutes;
                    var isUrgent = minutesLeft < 5;
                    <div class="card" style="
                        border:1px solid rgba(16,185,129,.4);
                        background:linear-gradient(135deg,rgba(16,185,129,.07) 0%,rgba(5,150,105,.04) 100%);
                        overflow:hidden;position:relative;">
                        <!-- Dải trang trí bên trái -->
                        <div style="position:absolute;left:0;top:0;bottom:0;width:5px;background:linear-gradient(to bottom,#10b981,#059669);"></div>
                        <div class="card-body" style="padding:1.4rem 1.4rem 1.4rem 1.75rem;">
                            <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
                                <div>
                                    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.5rem;flex-wrap:wrap;">
                                        <span style="font-size:1.8rem;line-height:1;">🎁</span>
                                        <div>
                                            <div style="font-family:monospace;font-size:1.2rem;font-weight:800;
                                                color:#10b981;letter-spacing:.12em;">
                                                @v.VoucherCode
                                            </div>
                                            <div class="muted text-sm">Cấp lúc @v.IssuedAt.ToString("HH:mm · dd/MM/yyyy")</div>
                                        </div>
                                    </div>

                                    <div style="display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
                                        <div>
                                            <div class="muted text-sm">Giảm giá</div>
                                            <div style="font-size:1.8rem;font-weight:800;color:#10b981;line-height:1;">
                                                @v.DiscountPercent%
                                            </div>
                                        </div>
                                        <div>
                                            <div class="muted text-sm">Áp dụng cho</div>
                                            <div class="fw-semi">@ServiceTypeLabel(v.ApplicableType)</div>
                                        </div>
                                        <div>
                                            <div class="muted text-sm">Hết hạn</div>
                                            <div class="fw-semi @(isUrgent ? "text-danger" : "")"
                                                 style="@(isUrgent ? "color:#f87171;" : "")">
                                                @v.ExpiresAt.ToString("HH:mm dd/MM")
                                                @if (isUrgent)
                                                {
                                                    <span style="font-size:.7rem;padding:.15rem .4rem;background:rgba(239,68,68,.2);
                                                        color:#f87171;border-radius:4px;margin-left:.3rem;">
                                                        🔥 @minutesLeft phút nữa
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    @* AI lý do cấp *@
                                    <div style="margin-top:.85rem;padding:.5rem .75rem;
                                        background:rgba(255,255,255,.04);border-radius:6px;
                                        border-left:3px solid rgba(16,185,129,.4);
                                        font-size:.78rem;color:rgba(255,255,255,.55);">
                                        🤖 AI cấp dựa trên: phân tích hành vi duyệt web &amp; dự đoán Revenue model
                                    </div>
                                </div>

                                <div style="display:flex;flex-direction:column;gap:.5rem;align-items:flex-end;">
                                    @if (!string.IsNullOrEmpty(v.ApplicableType) && v.ApplicableType != "All" && v.ApplicableType != "Test")
                                    {
                                        <a href="/@v.ApplicableType@(v.ApplicableId.HasValue ? "/Details/"+v.ApplicableId : "")"
                                            class="btn btn-primary" style="font-size:.82rem;padding:.45rem 1rem;">
                                            Dùng ngay →
                                        </a>
                                    }
                                    <button onclick="copyCode('@v.VoucherCode')"
                                        id="copy-@v.Id"
                                        style="padding:.45rem 1rem;background:transparent;
                                            border:1px solid rgba(16,185,129,.4);border-radius:8px;
                                            color:#10b981;cursor:pointer;font-size:.82rem;">
                                        📋 Sao chép
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @* Voucher đã dùng / hết hạn *@
        @if (expired.Any())
        {
            <h2 style="font-size:1rem;font-weight:700;margin-bottom:1rem;display:flex;align-items:center;gap:.6rem;color:rgba(255,255,255,.5);">
                <span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:rgba(255,255,255,.25);"></span>
                Đã sử dụng / Hết hạn
                <span style="font-size:.7rem;font-weight:700;padding:.15rem .5rem;
                    background:rgba(255,255,255,.06);color:rgba(255,255,255,.4);
                    border-radius:999px;border:1px solid rgba(255,255,255,.1);">
                    @expired.Count
                </span>
            </h2>
            <div style="display:grid;gap:.75rem;opacity:.55;">
                @foreach (var v in expired.Take(5))
                {
                    <div class="card" style="padding:1rem 1.2rem;">
                        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;">
                            <div>
                                <span style="font-family:monospace;font-weight:700;letter-spacing:.08em;
                                    text-decoration:line-through;color:rgba(255,255,255,.4);">
                                    @v.VoucherCode
                                </span>
                                <span style="margin-left:.75rem;font-size:.72rem;padding:.15rem .4rem;
                                    background:rgba(255,255,255,.05);border-radius:4px;">
                                    @(v.IsUsed ? "✓ Đã dùng" : "⏰ Hết hạn")
                                </span>
                            </div>
                            <div class="muted text-sm">
                                Giảm @v.DiscountPercent% · @ServiceTypeLabel(v.ApplicableType)
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Quay lại -->
        <div class="mt-4">
            <a asp-controller="Recommendation" asp-action="Index" class="btn btn-outline" style="font-size:.85rem;">
                ← Quay lại Dành cho bạn
            </a>
        </div>

    </div>
</div>

@functions {
    string ServiceTypeLabel(string t) => t switch {
        "Hotel"    => "🏨 Khách sạn",
        "Flight"   => "✈️ Chuyến bay",
        "Tour"     => "🗺️ Tour",
        "Car"      => "🚙 Thuê xe",
        "Transfer" => "🚗 Đưa đón",
        "Test"     => "🧪 Voucher test",
        "All"      => "Tất cả dịch vụ",
        _          => t ?? "Dịch vụ"
    };
}

@section Scripts {
<script>
async function testVoucher() {
    const btn = document.getElementById('btn-test-voucher');
    const resultEl = document.getElementById('test-result');
    btn.disabled = true;
    btn.textContent = '⏳ Đang gọi AI...';
    resultEl.style.display = 'none';

    try {
        const res  = await fetch('/Recommendation/TestVoucher', { method: 'POST' });
        const data = await res.json();

        if (data.success) {
            resultEl.style.display = 'block';
            resultEl.innerHTML = `
                <div style="
                    background:linear-gradient(135deg,#065f46,#047857);
                    border:1.5px solid #10b981;border-radius:14px;
                    padding:1.25rem 1.5rem;animation:vtFadeIn .4s ease;
                ">
                    <div style="display:flex;align-items:center;gap:.85rem;flex-wrap:wrap;">
                        <span style="font-size:2.5rem;line-height:1;">✅</span>
                        <div>
                            <div style="font-weight:700;font-size:1rem;color:#fff;margin-bottom:.3rem;">
                                AI đã cấp Voucher Test thành công!
                            </div>
                            <div style="font-family:monospace;font-size:1.15rem;font-weight:800;
                                color:#6ee7b7;letter-spacing:.12em;">${data.code}</div>
                            <div style="font-size:.82rem;color:rgba(255,255,255,.7);margin-top:.3rem;">
                                Giảm <strong style="color:#6ee7b7;">${data.discount}%</strong>
                                &nbsp;·&nbsp; Hết hạn 30 phút
                            </div>
                        </div>
                    </div>
                    <div style="margin-top:.85rem;padding:.6rem .85rem;
                        background:rgba(0,0,0,.25);border-radius:8px;
                        font-size:.78rem;color:rgba(255,255,255,.6);">
                        🤖 <strong style="color:#6ee7b7;">Quyết định AI:</strong>
                        ${data.aiDecision || 'model dự đoán Revenue → cấp voucher'}
                    </div>
                    <div style="margin-top:.75rem;display:flex;gap:.5rem;flex-wrap:wrap;">
                        <button onclick="location.reload()"
                            style="padding:.45rem 1rem;background:rgba(255,255,255,.2);
                                border:none;border-radius:8px;color:#fff;
                                cursor:pointer;font-size:.82rem;font-weight:600;">
                            🔄 Làm mới trang
                        </button>
                        <button onclick="navigator.clipboard?.writeText('${data.code}').then(()=>{this.textContent='✓ Đã sao chép'})"
                            style="padding:.45rem 1rem;background:transparent;
                                border:1px solid rgba(255,255,255,.3);border-radius:8px;
                                color:rgba(255,255,255,.7);cursor:pointer;font-size:.82rem;">
                            📋 ${data.code}
                        </button>
                    </div>
                </div>
                <style>@@keyframes vtFadeIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}</style>`;
        } else {
            resultEl.style.display = 'block';
            resultEl.innerHTML = `<div class="card" style="padding:1rem;border:1px solid rgba(239,68,68,.3);color:#f87171;">
                ❌ Lỗi: ${data.error || 'Không xác định'}
            </div>`;
        }
    } catch(e) {
        resultEl.style.display = 'block';
        resultEl.innerHTML = `<div class="card" style="padding:1rem;color:#f87171;">❌ ${e.message}</div>`;
    }

    btn.disabled = false;
    btn.textContent = '⚡ Test Voucher ngay';
}

function copyCode(code) {
    navigator.clipboard?.writeText(code).then(() => {
        // Tìm nút copy theo code
        document.querySelectorAll('button').forEach(btn => {
            if (btn.textContent.includes('Sao chép')) {
                const card = btn.closest('.card');
                if (card?.querySelector('div')?.textContent?.includes(code)) {
                    const orig = btn.textContent;
                    btn.textContent = '✓ Đã sao chép!';
                    btn.style.color = '#10b981';
                    setTimeout(() => { btn.textContent = orig; btn.style.color = ''; }, 2000);
                }
            }
        });
    });
}
</script>
}
